@page
@model asp.Pages.Manager.CreateOrderModel
@{
    ViewData["Title"] = "Создание заказа";
}

<div class="container mt-4">
    <h1>Создание заказа</h1>

    <form method="post">
        <div class="row">
            <div class="col-md-8">
                <div class="mb-3">
                    <label for="clientId" class="form-label">Клиент</label>
                    <select class="form-control" id="clientId" name="clientId" asp-items="Model.Clients" required>
                        <option value="">Выберите клиента</option>
                    </select>
                    <a href="/Manager/CreateClient" class="btn btn-link">Добавить клиента</a>
                </div>

                <div class="mb-3">
                    <label for="deviceType" class="form-label">Тип устройства</label>
                    <input type="text" class="form-control" id="deviceType" name="deviceType" value="@Model.DeviceType" required />
                </div>

                <div class="mb-3">
                    <label for="deviceModel" class="form-label">Модель устройства</label>
                    <input type="text" class="form-control" id="deviceModel" name="deviceModel" value="@Model.DeviceModel" required />
                </div>

                <div class="mb-3">
                    <label for="problemDescription" class="form-label">Описание проблемы</label>
                    <textarea class="form-control" id="problemDescription" name="problemDescription" rows="3" required>@Model.ProblemDescription</textarea>
                </div>

                <div class="mb-3">
                    <label for="notes" class="form-label">Примечания</label>
                    <textarea class="form-control" id="notes" name="notes" rows="2">@Model.Notes</textarea>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Функции БД</h5>
                        <button type="submit" name="action" value="findMaster" class="btn btn-outline-info w-100">Найти свободного мастера</button>
                        @if (Model.RecommendedMasterId.HasValue)
                        {
                            <div class="alert alert-success mt-2 mb-0">
                                <strong>ID свободного мастера:</strong> @Model.RecommendedMasterId
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <button type="submit" name="action" value="diagnostic" class="btn btn-primary">Создать заказ (отправить на диагностику)</button>
        <button type="submit" name="action" value="repair" class="btn btn-success">Создать заказ (сразу на ремонт)</button>
        <a href="/Manager/Orders" class="btn btn-secondary">Отмена</a>
    </form>
</div>
